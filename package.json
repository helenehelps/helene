{
  "name": "helene",
  "description": "Helene helps you to focus on your idea flow.",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "review": "prettier --check . && oxlint && npm run d:scss && tsc --noEmit",
    "database": "docker compose --env-file .env.development up database -d",
    "test": "vitest run",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "d:scss": "tsx scripts/scss-module-dts.run.ts | pino-pretty",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "next": "^15.5.3",
    "next-intl": "^4.3.9",
    "pino": "^9.11.0",
    "postgres": "^3.4.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@storybook/addon-a11y": "^9.1.7",
    "@storybook/addon-docs": "^9.1.7",
    "@storybook/addon-themes": "^9.1.7",
    "@storybook/addon-vitest": "^9.1.7",
    "@storybook/nextjs-vite": "^9.1.7",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.4",
    "glob": "^11.0.3",
    "oxlint": "^1.16.0",
    "pino-pretty": "^13.1.1",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-toml": "^2.0.6",
    "sass": "^1.93.2",
    "storybook": "^9.1.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vitest": "^3.2.4"
  }
}
